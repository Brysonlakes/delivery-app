generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  role           String   @default("customer") // "customer" | "shop_owner" | "admin" | "driver"
  fullName       String
  phone          String?
  createdAt      DateTime @default(now())
  shop           Shop?
  orders         Order[] // orders placed by this user (customer)
  ordersAsDriver Order[]  @relation("DriverOrders") // orders delivered by this user (driver)
}

model Shop {
  id          String     @id @default(uuid())
  ownerId     String     @unique
  owner       User       @relation(fields: [ownerId], references: [id])
  name        String
  description String?
  address     String
  isApproved  Boolean    @default(false)
  isOpen      Boolean    @default(true)
  categories  Category[]
  menuItems   MenuItem[]
  orders      Order[]

  payfastMerchantId  String?
  payfastMerchantKey String?
  payfastPassphrase  String?
  yocoSecretKey      String? // <-- must be present
  eftBankName        String? // <-- must be present
  eftAccountNumber   String? // <-- must be present
  eftAccountHolder   String? // <-- must be present
  paystackSecretKey  String? // <-- add this line
}

model Category {
  id     String     @id @default(uuid())
  shopId String
  shop   Shop       @relation(fields: [shopId], references: [id])
  name   String
  items  MenuItem[]
}

model MenuItem {
  id                String      @id @default(uuid())
  shopId            String
  shop              Shop        @relation(fields: [shopId], references: [id])
  categoryId        String?
  category          Category?   @relation(fields: [categoryId], references: [id])
  name              String
  description       String?
  price             Float
  imageUrl          String?
  dietaryTags       String?
  isAvailable       Boolean     @default(true)
  stockQuantity     Int?
  lowStockThreshold Int?
  orderItems        OrderItem[]
}

model Order {
  id            String      @id @default(uuid())
  customerId    String
  customer      User        @relation(fields: [customerId], references: [id])
  shopId        String
  shop          Shop        @relation(fields: [shopId], references: [id])
  driverId      String?
  driver        User?       @relation("DriverOrders", fields: [driverId], references: [id])
  status        String      @default("pending") // pending, accepted, preparing, ready_for_pickup, out_for_delivery, delivered, cancelled
  totalAmount   Float
  paymentStatus String      @default("pending") // pending, cash_pending, eft_pending, paid
  items         OrderItem[]
  createdAt     DateTime    @default(now())

  deliveryFee     Float  @default(0)
  shopOwnerAmount Float?
  driverAmount    Float?
  platformAmount  Float?

  payoutId String?
  payout   Payout? @relation(fields: [payoutId], references: [id])
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  itemPrice  Float
}

model PlatformConfig {
  id                Int     @id @default(autoincrement())
  paystackSecretKey String?
}

model Payout {
  id        String   @id @default(uuid())
  userId    String
  role      String // "shop_owner" or "driver"
  amount    Float
  status    String   @default("pending") // "pending" | "paid"
  createdAt DateTime @default(now())
  orders    Order[] // orders included in this payout
}
